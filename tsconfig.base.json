{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": false,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "preserve",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@test-task-insilicobiotech/shared/layout/main-layout/feature": [
        "./libs/shared/layout/main-layout/feature/src/index.ts"
      ],
      "@test-task-insilicobiotech/shared/layout/main-header/feature": [
        "./libs/shared/layout/main-header/feature/src/index.ts"
      ],
      "@test-task-insilicobiotech/medium-dashboard/models": [
        "./libs/medium-dashboard/models/src/index.ts"
      ],
      "@test-task-insilicobiotech/medium-dashboard/feature": [
        "./libs/medium-dashboard/feature/src/index.ts"
      ],
      "@test-task-insilicobiotech/medium-dashboard/ui/models": [
        "./libs/medium-dashboard/ui/models/src/index.ts"
      ],
      "@test-task-insilicobiotech/medium-dashboard/data-access": [
        "./libs/medium-dashboard/data-access/src/index.ts"
      ],
      "@test-task-insilicobiotech/medium-dashboard/utils": [
        "./libs/medium-dashboard/utils/src/index.ts"
      ],
      "@test-task-insilicobiotech/medium-dashboard/ui/chart": [
        "./libs/medium-dashboard/ui/chart/src/index.ts"
      ],
      "@test-task-insilicobiotech/medium-dashboard/constants": [
        "./libs/medium-dashboard/constants/src/index.ts"
      ],
    }
  },
  "exclude": ["node_modules", "tmp"]
}
