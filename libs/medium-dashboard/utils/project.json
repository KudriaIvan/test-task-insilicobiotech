{
  "name": "medium-dashboard-utils",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/medium-dashboard/utils/src",
  "projectType": "library",
  "tags": ["type:utils"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/medium-dashboard/utils",
        "main": "libs/medium-dashboard/utils/src/index.ts",
        "tsConfig": "libs/medium-dashboard/utils/tsconfig.lib.json",
        "assets": ["libs/medium-dashboard/utils/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/medium-dashboard/utils/jest.config.cts",
        "tsConfig": "libs/medium-dashboard/utils/tsconfig.spec.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
